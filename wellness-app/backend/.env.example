# MongoDB Connection
MONGODB_URL=mongodb+srv://your_user:your_password@your_cluster.mongodb.net/?appName=YourApp
DATABASE_NAME=wellness_db

# JWT Security
SECRET_KEY=change-this-secret-key-in-production-must-be-long-and-random-32chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Hugging Face AI Integration
HF_TOKEN=hf_your_hugging_face_token_here
AI_API_ENDPOINT=https://api-inference.huggingface.co/models/
